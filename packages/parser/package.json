{
  "name": "@repohive/parser",
  "version": "0.0.0",
  "private": true,
  "description": "RepoHIVE dependency graph parser — Java source → cross-file graph.json.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "parse": "node ./dist/parse-cli.js",
    "demo:determinism": "node ./dist/demo-determinism.js"
  },
  "dependencies": {
    "@repohive/shared": "0.0.0",
    "graphology": "0.26.0",
    "tree-sitter-java": "0.23.5",
    "web-tree-sitter": "0.26.10"
  },
  "devDependencies": {
    "fast-check": "4.8.0"
  },
  "license": "MIT"
}
